# =============================================
# Firstframe V1 — Environment Variables
# =============================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to git!
# =============================================

# =============================================
# Firebase Client SDK
# Get from: Firebase Console → Project Settings → Your Apps → Web
# =============================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# =============================================
# Firebase Admin SDK (Server-side only)
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the ENTIRE downloaded JSON on a SINGLE line below
# =============================================
FIREBASE_SERVICE_ACCOUNT_KEY=

# =============================================
# JWT Secret
# Generate: any random string, 32+ characters
# =============================================
JWT_SECRET=change-this-to-a-random-string-in-production

# =============================================
# Resend Email API (optional for V1)
# Sign up at https://resend.com
# =============================================
RESEND_API_KEY=re_demo_key
RESEND_FROM_EMAIL=onboarding@resend.dev

# =============================================
# App URL
# =============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
